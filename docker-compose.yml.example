services:
  backend:
    build:
      context: .
      dockerfile: Dockerfile.backend
    volumes:
      - ./data:/app/data  # Persistência do banco SQLite
    env_file:
      - .env
    environment:
      - ENV=prod
      - DB_BACKEND=sqlite
      # FRONTEND_URL precisa estar aqui para pegar o IP dinâmico via ${VM_IP}
      - FRONTEND_URL=https://${VM_IP}
    restart: always

  frontend:
    build:
      context: .
      dockerfile: Dockerfile.frontend
    environment:
      # O frontend (Python) e o navegador precisam saber onde está a API.
      # Como estamos usando Nginx, a API está em /api no mesmo domínio/IP.
      - API_BASE_URL=https://${VM_IP}/api
      - ENV=prod
      - FRONTEND_URL=https://${VM_IP}
    depends_on:
      - backend
    restart: always

  nginx:
    image: nginx:alpine
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/conf.d:/etc/nginx/conf.d
      - ./nginx/certs:/etc/nginx/certs
    depends_on:
      - backend
      - frontend
    restart: always
